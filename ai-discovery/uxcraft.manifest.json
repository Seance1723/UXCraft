{
  "schema_version": "1.0",
  "name": "uxcraft",
  "title": "UXCraft",
  "version": "1.5.4",
  "author": "Rupak Biswas",
  "description": "One-stop UXCraft skill for AI agents with opt-in /uxcraft activation, system prompt add-ons, project-local skill assets, and local MCP discovery.",
  "activation": {
    "trigger": "/uxcraft",
    "mode": "opt-in-only",
    "do_not_auto_apply_without_trigger": true
  },
  "entrypoints": {
    "skill": "SKILL.md",
    "readme": "README.md",
    "llms": "llms.txt",
    "mcp_server_bin": "uxcraft-mcp",
    "cli_bin": "uxcraft"
  },
  "system_prompt_addons": [
    "system-prompts/uxcraft-system-add-on.md",
    "system-prompts/uxcraft-compact.md",
    "system-prompts/uxcraft-mcp-add-on.md"
  ],
  "mcp": {
    "server_name": "uxcraft",
    "transport": "stdio",
    "command": "npx",
    "args": ["-y", "--package", "uxcraft", "uxcraft-mcp"],
    "tools": [
      "get_skill",
      "list_assets",
      "get_asset",
      "generate_system_prompt",
      "create_memory_template",
      "install_instructions"
    ],
    "resources": [
      "uxcraft://skill",
      "uxcraft://readme",
      "uxcraft://llms",
      "uxcraft://manifest",
      "uxcraft://system-prompt",
      "uxcraft://compact-prompt",
      "uxcraft://mcp-prompt",
      "uxcraft://mcp-docs",
      "uxcraft://checklist",
      "uxcraft://memory-template"
    ],
    "prompts": [
      "uxcraft",
      "ui-ux-audit",
      "ui-ux-redesign",
      "ui-ux-design-system",
      "ui-ux-accessibility-review"
    ]
  },
  "supported_agents": [
    "Claude Code",
    "Codex",
    "Windsurf",
    "Antigravity",
    "Gemini CLI",
    "Cursor",
    "MCP clients",
    "Universal agents"
  ],
  "capabilities": [
    "UX strategy",
    "UX research planning",
    "information architecture",
    "user flows",
    "wireframes",
    "visual design direction",
    "design systems",
    "accessibility",
    "responsive design",
    "content design",
    "localization",
    "ethical UX",
    "frontend implementation handoff",
    "QA and acceptance criteria"
  ]
}
